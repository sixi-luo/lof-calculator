# LOF计算器环境变量配置
# 复制此文件为 .env.local 并填入实际值

# TickFlow API密钥 (从 https://tickflow.org 获取)
TICKFLOW_API_KEY=your_tickflow_api_key_here

# 东方财富API相关配置（可选）
# EASTMONEY_API_KEY=your_eastmoney_api_key_here

# 缓存配置（毫秒）
CACHE_QUOTE_TTL=30000
CACHE_NAV_TTL=300000
CACHE_INDEX_TTL=30000
CACHE_KLINE_TTL=86400000
CACHE_BATCH_TTL=60000
CACHE_HISTORY_TTL=86400000

# 重试配置
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000

# 开发配置
NODE_ENV=development
NEXT_PUBLIC_DEBUG=false